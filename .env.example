# انسخ هذا الملف إلى .env وعدّل القيم (لا ترفع .env إطلاقاً)

# مفتاح الجلسات — استبدله بنص عشوائي طويل
SECRET_KEY=ضع_نصاً_عشوائياً_طويلاً_هنا

# مفتاح تشفير البيانات الحساسة — ولّده مرة واحدة بالأمر:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# رابط التطبيق العام (يُستخدم في روابط التحقق بالإيميل)
PUBLIC_BASE_URL=https://username.pythonanywhere.com

# المنطقة الزمنية
TIMEZONE=Africa/Cairo
